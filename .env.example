# Solana Network Configuration
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com
NEXT_PUBLIC_SOLANA_NETWORK=devnet

# Platform Fee Wallet — Your wallet address that receives the 0.1 SOL platform fee per flip
# Replace this with YOUR Solana wallet public key
NEXT_PUBLIC_PLATFORM_FEE_WALLET=ReplaceWithYourWalletPublicKey

# Platform Fee Amount in SOL
NEXT_PUBLIC_PLATFORM_FEE=0.1

# Old Anchor program variables (not needed for fee-based mode)
NEXT_PUBLIC_PROGRAM_ID=ReplaceWithDeployedProgramId
NEXT_PUBLIC_HOUSE_PDA=ReplaceWithHousePda
NEXT_PUBLIC_VAULT_PDA=ReplaceWithVaultPda
